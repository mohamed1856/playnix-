let games = [];
let cpus = [];
let gpus = [];

async function loadData() {
    try {
        // حل مشكلة البطء: جلب الملفات الثلاثة معاً في نفس الوقت التوازي
        const [gamesRes, cpusRes, gpusRes] = await Promise.all([
            fetch("data/games.json").then(r => r.json()),
            fetch("data/cpus.json").then(r => r.json()),
            fetch("data/gpus.json").then(r => r.json())
        ]);

        games = gamesRes;
        cpus = cpusRes;
        gpus = gpusRes;

        // استدعاء دالة موحدة لتعبئة القوائم
        fillSelect("game", games);
        fillSelect("cpu", cpus);
        fillSelect("gpu", gpus);
        
    } catch (error) {
        // معالجة الأخطاء في حال فشل الجلب
        console.error("خطأ في تحميل البيانات التوضيحية:", error);
    }
}

// دالة موحدة بدلاً من التكرار لحل مشكلة الأداء
function fillSelect(elementId, data) {
    const select = document.getElementById(elementId);
    if (!select) return;

    // حل مشكلة innerHTML += : تجميع العناصر في مصفوفة وحقنها دفعة واحدة
    const optionsHTML = data.map(item => {
        const value = item.score || item.name; 
        return `<option value="${value}">${item.name}</option>`;
    }).join('');

    select.innerHTML = optionsHTML;
}

function checkGame() {
    document.getElementById("result").innerHTML = "✅ الفحص يعمل بنجاح";
}

// تشغيل الدالة الأساسية
loadData();
