let games = [];
let cpus = [];
let gpus = [];

async function loadData() {
    try {
        // تحميل كافة البيانات في وقت واحد لتوفير الوقت
        const [gamesRes, cpusRes, gpusRes] = await Promise.all([
            fetch("data/games.json").then(r => r.json()),
            fetch("data/cpus.json").then(r => r.json()),
            fetch("data/gpus.json").then(r => r.json())
        ]);

        games = gamesRes;
        cpus = cpusRes;
        gpus = gpusRes;

        fillSelect("game", games);
        fillSelect("cpu", cpus);
        fillSelect("gpu", gpus);
        
    } catch (error) {
        console.error("حدث خطأ أثناء تحميل البيانات:", error);
    }
}

// دالة واحدة مختصرة بدلاً من تكرار الأكواد لـ 3 دوال
function fillSelect(elementId, data) {
    const select = document.getElementById(elementId);
    if (!select) return;

    // تجميع الخيارات في مصفوفة ثم تحويلها لنص واحد (أسرع بكثير)
    const options = data.map(item => {
        // استخدام السعر أو النقاط كقيمة، والاسم كنص معروض
        const value = item.score || item.name; 
        return `<option value="${value}">${item.name}</option>`;
    }).join('');

    select.innerHTML = options;
}

function checkGame() {
    document.getElementById("result").innerHTML = "✅ الفحص يعمل بنجاح";
}

loadData();
